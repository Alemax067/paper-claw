# Paper Claw environment example
# Copy to .env and fill values locally. Do not commit real secrets.

# App/runtime
PAPER_CLAW_ENVIRONMENT=development
PAPER_CLAW_DATABASE_URL=postgresql+psycopg://paper_claw:paper_claw@localhost:5432/paper_claw
PAPER_CLAW_DATA_DIR=./data
PAPER_CLAW_STORAGE_ROOT=./data/files

# PostgreSQL Docker defaults
POSTGRES_DB=paper_claw
POSTGRES_USER=paper_claw
POSTGRES_PASSWORD=paper_claw
POSTGRES_PORT=5432

# Runtime chat model configuration
PAPER_CLAW_CHAT_API_KEY=
PAPER_CLAW_CHAT_BASE_URL=
PAPER_CLAW_CHAT_MODEL=
PAPER_CLAW_CHAT_TEMPERATURE=0.2
PAPER_CLAW_CHAT_MAX_TOKENS=4096
PAPER_CLAW_CHAT_TIMEOUT_SECONDS=60
PAPER_CLAW_CHAT_MAX_RETRIES=2
PAPER_CLAW_CHAT_RATE_LIMITER_REQUESTS_PER_SECOND=
PAPER_CLAW_CHAT_RATE_LIMITER_CHECK_EVERY_N_SECONDS=0.1
PAPER_CLAW_CHAT_RATE_LIMITER_MAX_BUCKET_SIZE=10

# Runtime embedding model configuration
PAPER_CLAW_EMBEDDING_API_KEY=
PAPER_CLAW_EMBEDDING_BASE_URL=
PAPER_CLAW_EMBEDDING_MODEL=
PAPER_CLAW_EMBEDDING_DIMENSION=1536
PAPER_CLAW_EMBEDDING_MAX_CONTEXT_TOKENS=8192
PAPER_CLAW_TOKENIZER_ENCODING=cl100k_base
PAPER_CLAW_EMBEDDING_TIMEOUT_SECONDS=60
PAPER_CLAW_EMBEDDING_MAX_RETRIES=2

# arXiv integration: queries and downloads share this limiter
PAPER_CLAW_ARXIV_MIN_INTERVAL_SECONDS=1.0
PAPER_CLAW_ARXIV_MAX_RETRIES=3
PAPER_CLAW_ARXIV_BACKOFF_BASE_SECONDS=1.0
PAPER_CLAW_ARXIV_BACKOFF_MAX_SECONDS=30.0
PAPER_CLAW_ARXIV_TIMEOUT_SECONDS=30

# OpenAlex integration
PAPER_CLAW_OPENALEX_EMAIL=
PAPER_CLAW_OPENALEX_API_KEY=
PAPER_CLAW_OPENALEX_TIMEOUT_SECONDS=30

# Runtime local OCR parser configuration
PAPER_CLAW_LOCAL_OCR_API_KEY=EMPTY
PAPER_CLAW_LOCAL_OCR_BASE_URL=
PAPER_CLAW_LOCAL_OCR_MODEL=Logics-Parsing
PAPER_CLAW_LOCAL_OCR_PROMPT=QwenVL HTML
PAPER_CLAW_LOCAL_OCR_MAX_TOKENS=16384
PAPER_CLAW_LOCAL_OCR_TEMPERATURE=0.1
PAPER_CLAW_LOCAL_OCR_TOP_P=0.5
PAPER_CLAW_LOCAL_OCR_REPETITION_PENALTY=1.05
PAPER_CLAW_LOCAL_OCR_DPI=200
PAPER_CLAW_LOCAL_OCR_TIMEOUT_SECONDS=300

# Runtime LlamaParse fallback parser configuration
PAPER_CLAW_LLAMA_PARSE_API_KEY=
PAPER_CLAW_LLAMA_PARSE_TIER=cost_effective
PAPER_CLAW_LLAMA_PARSE_VERSION=latest
PAPER_CLAW_LLAMA_PARSE_TIMEOUT_SECONDS=300
PAPER_CLAW_LLAMA_PARSE_EXTRA_TIME_PER_PAGE_SECONDS=45
PAPER_CLAW_LLAMA_PARSE_IMAGE_MIN_PIXELS=200000
